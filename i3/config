# i3 config for deva on Ubuntu 25.10

set $mod Mod4
set $terminal ptyxis --new-window
set $launcher i3-dmenu-desktop
set $raw_launcher dmenu_run
set $locker ~/.config/i3/scripts/lock.sh
set $refresh_i3status killall -SIGUSR1 i3status

font pango:JetBrains Mono 10

floating_modifier $mod
tiling_drag modifier titlebar
focus_follows_mouse no
mouse_warping none
workspace_auto_back_and_forth yes

gaps inner 8
gaps outer 2
smart_gaps on
hide_edge_borders smart_no_gaps

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id ~/.config/i3/scripts/startup-services.sh
exec --no-startup-id xss-lock --transfer-sleep-lock -- $locker --nofork
exec_always --no-startup-id ~/.config/i3/scripts/monitor-setup.sh
exec_always --no-startup-id setxkbmap -option caps:escape
exec_always --no-startup-id sh -c '[ -f ~/.Xresources ] && xrdb -merge ~/.Xresources'
exec_always --no-startup-id sh -c '[ -f ~/Pictures/wall.jpg ] && feh --no-fehbg --bg-fill ~/Pictures/wall.jpg'
exec_always --no-startup-id autotiling
exec_always --no-startup-id ~/.local/bin/i3-cycle-focus
exec --no-startup-id ptyxis --new-window --title=dropterm

set $dmenu_args -i -l 15 -fn "JetBrains Mono-11" -nb "#171717" -nf "#d1d5db" -sb "#2563eb" -sf "#ffffff" -p "run:"

bindsym $mod+Return exec --no-startup-id $terminal
bindsym $mod+Shift+q kill
bindsym $mod+d exec --no-startup-id i3-dmenu-desktop --dmenu="dmenu $dmenu_args"
bindsym $mod+Shift+d exec --no-startup-id sh -c "dmenu_run $dmenu_args"
bindsym $mod+Shift+v exec --no-startup-id pavucontrol
bindsym $mod+Shift+x exec --no-startup-id $locker
bindsym Print exec --no-startup-id flameshot gui
bindsym $mod+Print exec --no-startup-id flameshot full -c
bindsym $mod+Shift+e exec --no-startup-id ~/.config/i3/scripts/powermenu.sh
bindsym $mod+Shift+p exec "i3-nagbar -t warning -m 'Shut down?' -B 'Yes, shut down' 'systemctl poweroff'"
bindsym $mod+Shift+m exec --no-startup-id ~/.config/i3/scripts/display-off.sh
bindsym $mod+c exec --no-startup-id copyq toggle

# Notifications
bindsym $mod+n       exec --no-startup-id dunstctl close-all
bindsym $mod+Shift+n exec --no-startup-id dunstctl history-pop

# Rofi (alongside dmenu) + i3-cycle-focus
bindsym $mod+Tab          exec --no-startup-id ~/.local/bin/i3-cycle-focus --switch
bindsym $mod+Shift+Tab    exec --no-startup-id rofi -show window
bindsym $mod+Shift+Return exec --no-startup-id rofi -show ssh
bindsym $mod+period       exec --no-startup-id rofi -modi emoji -show emoji
bindsym $mod+Shift+w      exec --no-startup-id networkmanager_dmenu
bindsym $mod+Shift+b      exec --no-startup-id ~/.local/bin/rofi-bluetooth

# Dev workflow
bindsym $mod+p         exec --no-startup-id ~/.local/bin/rofi-projects
bindsym $mod+Shift+s exec --no-startup-id ~/.config/i3/scripts/resurrect-save.sh
bindsym $mod+Shift+o exec --no-startup-id ~/.config/i3/scripts/resurrect-restore.sh
bindsym $mod+Shift+y   exec --no-startup-id rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'

# Picture-in-picture / always-on-top
bindsym $mod+Shift+t floating enable, sticky toggle
bindsym $mod+Shift+u floating enable, sticky enable, resize set 640 360, move position bottom-right

# Window rules
for_window [class="Pavucontrol"]        floating enable, resize set 800 600, move position center
for_window [class="Blueman-manager"]    floating enable
for_window [class="copyq"]              floating enable
for_window [window_role="pop-up"]       floating enable
for_window [window_role="dialog"]       floating enable
for_window [title="Picture-in-Picture"] floating enable, sticky enable
for_window [title="^dropterm$"]         floating enable, resize set 1200 700, move scratchpad

# Dropdown terminal (ptyxis)
bindsym $mod+grave [title="^dropterm$"] scratchpad show, move position center

# Gaps adjustment (inc/dec via equal/Shift+equal — minus is taken by scratchpad)
bindsym $mod+equal       gaps inner current plus 4
bindsym $mod+Shift+equal gaps inner current minus 4
bindsym $mod+Shift+g     gaps inner current set 0; gaps outer current set 0
bindsym $mod+Ctrl+g      exec --no-startup-id ~/.config/i3/scripts/toggle-gaps.sh

# Quick resize (no mode entry)
bindsym $mod+Ctrl+Right resize grow   width  20 px or 5 ppt
bindsym $mod+Ctrl+Left  resize shrink width  20 px or 5 ppt
bindsym $mod+Ctrl+Down  resize grow   height 20 px or 5 ppt
bindsym $mod+Ctrl+Up    resize shrink height 20 px or 5 ppt

# Cheatsheet
bindsym $mod+F1 exec --no-startup-id ~/.config/i3/scripts/i3-help.sh

bindsym XF86AudioRaiseVolume exec --no-startup-id sh -c 'wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+ && killall -SIGUSR1 i3status'
bindsym XF86AudioLowerVolume exec --no-startup-id sh -c 'wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && killall -SIGUSR1 i3status'
bindsym XF86AudioMute exec --no-startup-id sh -c 'wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && killall -SIGUSR1 i3status'
bindsym XF86AudioMicMute exec --no-startup-id sh -c 'wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle && killall -SIGUSR1 i3status'
bindsym XF86AudioPlay exec --no-startup-id sh -c 'command -v playerctl >/dev/null 2>&1 && playerctl play-pause'
bindsym XF86AudioPause exec --no-startup-id sh -c 'command -v playerctl >/dev/null 2>&1 && playerctl pause'
bindsym XF86AudioNext exec --no-startup-id sh -c 'command -v playerctl >/dev/null 2>&1 && playerctl next'
bindsym XF86AudioPrev exec --no-startup-id sh -c 'command -v playerctl >/dev/null 2>&1 && playerctl previous'

set $left Left
set $down Down
set $up Up
set $right Right

bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Workspace -> monitor pinning (first available output wins)
workspace 1  output DP-4 DP-0 primary
workspace 2  output DP-4 DP-0 primary
workspace 3  output DP-4 DP-0 primary
workspace 4  output DP-4 DP-0 primary
workspace 5  output DP-4 DP-0 primary
workspace 9  output HDMI-2 DP-4 primary
workspace 10 output HDMI-2 DP-4 primary

bindsym $mod+Shift+r restart

mode "resize" {
    bindsym $left resize shrink width 10 px or 10 ppt
    bindsym $down resize grow height 10 px or 10 ppt
    bindsym $up resize shrink height 10 px or 10 ppt
    bindsym $right resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

bar {
    font pango:JetBrainsMono Nerd Font 10
    position top
    tray_output primary
    status_command /home/deva/.cargo/bin/i3status-rs ~/.config/i3status-rust/config.toml
    colors {
        background #000000
        statusline #f5f5f5
        separator  #4b5563

        focused_workspace  #2563eb #2563eb #ffffff
        active_workspace   #1f2937 #1f2937 #e5e7eb
        inactive_workspace #000000 #000000 #9ca3af
        urgent_workspace   #b91c1c #b91c1c #ffffff
    }
}

client.focused          #2563eb #2563eb #ffffff #2563eb #2563eb
client.focused_inactive #1f2937 #1f2937 #d1d5db #4b5563 #1f2937
client.unfocused        #171717 #171717 #9ca3af #374151 #171717
client.urgent           #b91c1c #b91c1c #ffffff #b91c1c #b91c1c
client.placeholder      #171717 #171717 #9ca3af #171717 #171717
client.background       #111827
