{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 6,

  // Bar-level fallback ÔÇö only fires over empty bar background.
  // Every module below gets the same pair via $scroll-up / $scroll-down
  // because GTK modules swallow scroll events instead of bubbling.
  "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
  "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1",

  "modules-left":   ["hyprland/workspaces", "hyprland/submap"],
  "modules-center": ["hyprland/window"],
  "modules-right":  ["custom/help", "tray", "mpris", "pulseaudio", "network", "cpu", "memory", "temperature", "idle_inhibitor", "custom/notif", "clock", "custom/power"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1",
    "warp-on-scroll": false,
    "disable-scroll": false,
    "all-outputs": true,
    "sort-by-number": true
  },
  "hyprland/window": {
    "max-length": 80,
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1"
  },
  "hyprland/submap": {
    "format": "[{}]",
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1"
  },

  "clock": {
    "on-click": "sh -c 'command -v gnome-calendar >/dev/null && gnome-calendar'",
    "format": "´ÇŚ  {:%H:%M  %a %d %b}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1"
  },
  "cpu": {
    "on-click": "ptyxis --new-window -- htop",
    "format": "´őŤ  {usage}%",
    "interval": 2,
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1"
  },
  "memory": {
    "on-click": "ptyxis --new-window -- htop",
    "format": "´öŞ  {percentage}%",
    "interval": 5,
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1"
  },
  "temperature": {
    "on-click": "ptyxis --new-window -- nvtop",
    // Read the real AMD Tctl sensor (hwmon.k10temp). The motherboard
    // acpitz zone on this board is pinned near ambient and doesn't
    // track load, so temps looked hardcoded at ~17┬░C. The pci device
    // path is stable across reboots; the hwmonN index is not.
    "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
    "input-filename": "temp1_input",
    "format":          "´őë  {temperatureC}┬░C",
    "format-critical": "´őë  {temperatureC}┬░C",
    "critical-threshold": 85,
    "interval": 2,
    "tooltip-format": "CPU (k10temp Tctl): {temperatureC}┬░C",
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1"
  },
  "network": {
    "on-click": "~/.local/bin/networkmanager_dmenu",
    "format-wifi":         "´çź  {essid}",
    "format-ethernet":     "´âĘ  eth",
    "format-disconnected": "´ü▒  off",
    "tooltip-format":      "{ifname}: {ipaddr}",
    "on-scroll-up":   "~/dotfiles/hypr/scripts/scroll-ws.sh e-1",
    "on-scroll-down": "~/dotfiles/hypr/scripts/scroll-ws.sh e+1"
  },
  "pulseaudio": {
    "format":        "{icon}  {volume}%",
    "format-muted":  "´Çž  muted",
    "format-icons":  { "headphone": "´Çą", "default": ["´Çž", "´Çž", "´ÇĘ"] },
    "on-click":          "pavucontrol",
    "on-click-right":    "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up":      "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 2%+",
    "on-scroll-down":    "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
  },
  "tray": {
    "spacing": 6
  },
  "custom/help": {
    "format": "´üÖ",
    "tooltip-format": "Keybinds ($mod+F1)",
    "on-click": "~/.config/hypr/scripts/hyprland-keybinds.sh"
  },
  "mpris": {
    "format":        "´üî  {status_icon}  {artist} ÔÇö {title}",
    "format-paused": "´üî  {status_icon}  {artist} ÔÇö {title}",
    "status-icons":  { "playing": "´üő", "paused": "´üî", "stopped": "ÔĆ╣" },
    "dynamic-order": ["title", "artist"],
    "max-length":    50,
    "interval":      1,
    "on-click":      "playerctl play-pause",
    "on-click-right":"playerctl next",
    "on-scroll-up":  "playerctl previous",
    "on-scroll-down":"playerctl next",
    "tooltip-format":"{player}: {artist} ÔÇö {title} ({status})"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": { "activated": "´â┤", "deactivated": "´ćć" },
    "tooltip-format-activated":   "Idle inhibited ÔÇö system won't sleep",
    "tooltip-format-deactivated": "Normal sleep behavior"
  },
  "custom/notif": {
    "exec": "~/.config/hypr/scripts/waybar-notif.sh",
    "return-type": "json",
    "interval": 2,
    "on-click":       "makoctl dismiss --all",
    "on-click-right": "~/.config/hypr/scripts/waybar-notif.sh --toggle-dnd",
    "tooltip": true
  },
  "custom/power": {
    "format": "´ÇĹ",
    "tooltip-format": "Power menu",
    "on-click": "~/.config/i3/scripts/powermenu.sh"
  }
}
