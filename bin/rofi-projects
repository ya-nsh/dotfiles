#!/bin/sh
set -eu

root="${PROJECTS_ROOT:-$HOME/Desktop/work}"
[ -d "$root" ] || { notify-send "rofi-projects" "no such dir: $root"; exit 1; }

proj=$(find "$root" -mindepth 1 -maxdepth 2 -type d \
        \( -name node_modules -o -name .git -o -name .next -o -name dist -o -name build \) -prune \
        -o -type d -print 2>/dev/null \
       | sed "s|$root/||" \
       | grep -v '^$' \
       | sort -u \
       | rofi -dmenu -i -p "project:" -theme-str 'window {width: 40%;}')

[ -z "$proj" ] && exit 0
dir="$root/$proj"

ptyxis --new-window --working-directory="$dir" >/dev/null 2>&1 &

if command -v cursor >/dev/null 2>&1; then
    cursor "$dir" >/dev/null 2>&1 &
elif command -v code >/dev/null 2>&1; then
    code "$dir" >/dev/null 2>&1 &
fi
